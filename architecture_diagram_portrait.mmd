graph TB
    %% Defining Styles
    classDef frontend fill:#1e1e2f,stroke:#60a5fa,stroke-width:2px,color:#fff;
    classDef backend fill:#1e1e2f,stroke:#34d399,stroke-width:2px,color:#fff;
    classDef database fill:#1e1e2f,stroke:#f59e0b,stroke-width:2px,color:#fff;
    classDef actor fill:#0f172a,stroke:#a78bfa,stroke-width:2px,color:#fff,shape:circle;
    classDef service fill:#1e1e2f,stroke:#f472b6,stroke-width:2px,color:#fff;

    %% Actors
    Admin((Admin)):::actor
    Client((Client)):::actor
    Crew((Prod Crew)):::actor

    %% Frontend Layer
    subgraph Frontend["React.js SPA (Client Layer)"]
        direction TB
        
        subgraph UI["Role-Specific Dashboards"]
            direction LR
            AdminDash["Admin Control Panel"]:::frontend
            ClientDash["Client Transparency View"]:::frontend
            CrewDash["Crew Task Tracker"]:::frontend
        end

        subgraph CoreComponents["Core UI Components"]
            BudgetForm["Multi-Phase Budget Matrix"]:::frontend
            Timeline["Interactive SVG Gantt Chart"]:::frontend
            MLUI["XGBoost Parameter Form"]:::frontend
            PDFGen["PDF Report Generator UI"]:::frontend
        end

        subgraph StateManagement["React Context Providers"]
            AuthCtx["Auth Context (RBAC & Session)"]:::frontend
            ProjectCtx["Project Context (Live Data)"]:::frontend
            ModalCtx["Modal/Overlay Context"]:::frontend
        end

        Axios["Axios HTTP Client (w/ Credentials)"]:::frontend

        UI --> CoreComponents
        CoreComponents --> StateManagement
        StateManagement --> Axios
    end

    %% Backend Layer
    subgraph Backend["Flask API (Server Layer)"]
        direction TB
        WSGI["Phusion Passenger (cPanel WSGI Gateway)"]:::backend
        AuthMiddleware["Session Handler (HTTP-Only Secure Cookies)"]:::backend
        
        subgraph Routes["RESTful Routing Modules"]
            direction TB
            AuthRoute["auth_management.py"]:::backend
            ProjectRoute["project_management.py"]:::backend
            BudgetRoute["budget_management.py"]:::backend
            ScheduleRoute["schedule_management.py"]:::backend
            NotifyRoute["notifications_management.py"]:::backend
            MLRoute["prediction_management.py"]:::backend
        end
        
        subgraph Services["Backend Services"]
            DBOps["db_operations.py (SQL Execution)"]:::backend
            PDFService["ReportLab PDF Engine"]:::backend
            Cloudinary["cloudinary_service.py"]:::service
        end

        WSGI --> AuthMiddleware
        AuthMiddleware --> Routes
        Routes --> Services
    end

    %% Data Layer
    subgraph DataLayer["Persistence & AI (Data Layer)"]
        direction TB
        MySQL[("MySQL Relational DB (Connection Pooling)")]:::database
        XGBoost["XGBoost Regressor (.pkl)"]:::database
        CloudStorage[("Cloudinary CDN (Images)")]:::database
        LocalPDF["Server File Storage (PDFs)"]:::database
    end

    %% Connections
    Admin --> AdminDash
    Client --> ClientDash
    Crew --> CrewDash

    Axios -- "HTTPS JSON Payload" --> WSGI
    
    DBOps -- "PyMySQL Transactions" --> MySQL
    MLRoute -- "Skew-Adjusted Features" --> XGBoost
    XGBoost -- "Estimated Budget Baseline" --> MLRoute
    BudgetRoute -- "Export Financials" --> PDFService
    PDFService -- "Write File" --> LocalPDF
    ProjectRoute -- "Upload Avatars/Banners" --> Cloudinary
    Cloudinary -- "API Requests" --> CloudStorage
